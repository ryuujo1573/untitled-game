{
  "name": "untitled-game",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && git_hash=$(git rev-parse --short HEAD) bun x --bun vite build",
    "pages:dev": "bun run build && wrangler pages dev dist",
    "pages:deploy": "bun run build && wrangler pages deploy dist --project-name voxel-demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:web": "tsc && vite build",
    "build:tauri": "tauri build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.2.5",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.0.18",
    "@webgpu/types": "^0.1.69",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.66.0"
  },
  "dependencies": {
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@tabler/icons-solidjs": "^3.38.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.4",
    "@tauri-apps/plugin-fs": "^2.0.4",
    "fflate": "^0.8.2",
    "flyonui": "^2.4.1",
    "gl-matrix": "^3.4.3",
    "lucide-solid": "^0.575.0",
    "solid-js": "^1.9.11",
    "tailwindcss": "^4.2.1"
  }
}
